# Domain and TLS
LAWAGENT_DOMAIN=lawagent.nickvbattaglia.com

# App security
ADMIN_PIN=change-this-admin-pin
FLASK_SECRET_KEY=change-this-long-random-secret
NODE_ENV=production

# Runtime mode controls
# auto           -> use LLM when available, deterministic fallback when unavailable
# llm            -> fail closed if Ollama is unavailable
# deterministic  -> never call Ollama
LAWAGENT_RUNTIME_MODE=auto
LAWAGENT_ALLOW_RUNTIME_MODE_OVERRIDE=true

# Database
POSTGRES_DB=lawagent_db
POSTGRES_USER=lawagent
POSTGRES_PASSWORD=change-this-db-password

# Home Ollama endpoint(s) (reachable from VPS over Tailscale)
# Primary only:
OLLAMA_BASE_URL=http://100.64.0.10:11434
# Optional app-level failover list (primary first, then fallback):
# OLLAMA_BASE_URLS=http://100.64.0.10:11434,http://100.64.0.11:11434
GRADER_MODEL=llama3.1:8b
GENERATOR_MODEL=command-r:7b
EMBEDDING_MODEL=nomic-embed-text
LLM_TIMEOUT=120
# Optional fail-fast controls for model outages / model-load failures
LLM_FAILURE_COOLDOWN_SEC=45
LLM_ENDPOINT_BACKOFF_SEC=30
LLM_MEMORY_COOLDOWN_SEC=300
# Optional vector embedding sync tuning
OLLAMA_EMBED_TIMEOUT_SEC=180
VECTOR_UPSERT_BATCH_SIZE=64
VECTOR_UPSERT_MIN_BATCH_SIZE=8
CRAG_MAX_GRADING_SECONDS=35
LAWAGENT_ENABLE_PER_ISSUE_LLM_ENHANCEMENT=false
LAWAGENT_ENABLE_PER_ISSUE_CORPUS_SUPPORT=false
